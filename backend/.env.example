# Environment Configuration
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.

# ── Flask ──────────────────────────────────────────────
# Options: development | testing | production
FLASK_ENV=development

# Secret key for session signing (generate a strong random string)
SECRET_KEY=change-me-to-a-random-secret-key

# ── Database ───────────────────────────────────────────
# SQLite (development):
DATABASE_URI=sqlite:///phishing_tool.db

# PostgreSQL (production) — uncomment and fill in:
# DATABASE_URI=postgresql://user:password@localhost:5432/phishing_tool

# ── ML Model ───────────────────────────────────────────
# Path to the saved .pkl model file (relative to backend/)
MODEL_PATH=app/ml/models/phishing_classifier.pkl

# ── CORS ───────────────────────────────────────────────
# Allowed frontend origin (Vite dev server)
CORS_ORIGINS=http://localhost:5173
